# Environment Variables — Pyrolysis ERP
# Copy this file to .env and fill in your values

# ── PostgreSQL Connection ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pyrolysis_erp
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ── Application ───────────────────────────────────────────────────────────────
PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars

# ── For Docker Compose deployment, use: ──────────────────────────────────────
# DB_HOST=postgres   (the Docker service name)
# DB_PORT=5432
# DB_NAME=pyrolysis_erp
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here
